<?xml version="1.0" encoding="UTF-8"?>
<!-- Run tests using phpunit -c doc/phpunit.xml -->
<phpunit
    colors="true"
	backupGlobals="false"
	bootstrap="phpunit_bootstrap.php"
>
	<php>
        <!-- Local override without committing: EGW_URL="http://your-host/egroupware" vendor/bin/phpunit -c doc/phpunit.xml -->
        <env name="EGW_URL" value="http://localhost/egroupware"/>
        <var name="EGW_DOMAIN" value="default" />
        <var name="EGW_USER" value="demo" />
        <var name="EGW_PASSWORD" value="guest" />
    </php>
	    <testsuites>
	        <testsuite name="Api">
	            <directory>../api/tests</directory>
	            <exclude>../api/tests/Etemplate/</exclude>
	            <exclude>../api/tests/EtemplateTest.php</exclude>
	            <exclude>../api/tests/AppTest.php</exclude>
	            <exclude>../api/tests/CalDAVTest.php</exclude>
	            <exclude>../api/tests/LoggedInTest.php</exclude>
	        </testsuite>
	        <testsuite name="Etemplate">
	            <file>../api/tests/EtemplateTest.php</file>
	            <directory>../api/tests/Etemplate/</directory>
	            <exclude>../api/tests/Etemplate/WidgetBaseTest.php</exclude>
	        </testsuite>
		<testsuite name="Apps">
			<!-- Apps with test directory -->
			<directory>../*/tests/</directory>

            <!-- Already done under "Api" testsuite -->
            <exclude>../api</exclude>

            <!-- Not properly working yet -->
            <exclude>../collabora</exclude>
            <exclude>../policy</exclude>
            <exclude>../stylite</exclude>
            <exclude>../invoices</exclude>
		</testsuite>
    </testsuites>
</phpunit>
