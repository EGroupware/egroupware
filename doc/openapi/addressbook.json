{
  "openapi": "3.0.3",
  "info": {
    "title": "EGroupware Addressbook REST API",
    "description": "REST API for managing contacts and contact groups in EGroupware Addressbook. Paths and examples follow the EGroupware GroupDAV/REST addressbook behavior. Request payloads use the flat slash-style field names shown in EGroupware examples.",
    "version": "1.0.0",
    "contact": {
      "name": "EGroupware",
      "url": "https://www.egroupware.org"
    },
    "license": {
      "name": "GPL",
      "url": "https://www.gnu.org/licenses/gpl-3.0.html"
    }
  },
  "servers": [
    {
      "url": "https://example.egroupware.org/egroupware/groupdav.php",
      "description": "EGroupware GroupDAV/REST Server"
    }
  ],
  "security": [
    {
      "basicAuth": []
    }
  ],
  "paths": {
    "/addressbook/": {
      "get": {
        "tags": [
          "Addressbook"
        ],
        "summary": "Search all addressbooks",
        "description": "Search in all addressbooks the current user has access to. Supports filtering, sync-token based sync, pagination, and selected properties.",
        "operationId": "searchContacts",
        "parameters": [
          {
            "$ref": "#/components/parameters/props"
          },
          {
            "$ref": "#/components/parameters/syncToken"
          },
          {
            "$ref": "#/components/parameters/nresults"
          },
          {
            "$ref": "#/components/parameters/filters_search"
          },
          {
            "$ref": "#/components/parameters/filters_linked"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactCollection"
                }
              },
              "application/pretty+json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactCollection"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/{username}/addressbook/": {
      "get": {
        "tags": [
          "Addressbook"
        ],
        "summary": "List or search contacts in the given user's addressbook",
        "description": "Returns all contacts in the given user's addressbook, provided the authenticated user has access. Supports filtering, sync-token based sync, pagination, and selected properties.",
        "operationId": "listContacts",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/props"
          },
          {
            "$ref": "#/components/parameters/syncToken"
          },
          {
            "$ref": "#/components/parameters/nresults"
          },
          {
            "$ref": "#/components/parameters/filters_search"
          },
          {
            "$ref": "#/components/parameters/filters_linked"
          }
        ],
        "responses": {
          "200": {
            "description": "A list of contacts",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactCollection"
                }
              },
              "application/pretty+json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactCollection"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "post": {
        "tags": [
          "Addressbook"
        ],
        "summary": "Create a new contact in the given user's addressbook",
        "description": "Adds a new contact to the addressbook. The request body uses the flat slash-style field names shown in EGroupware examples. The Location header in the response gives the URL of the new resource.",
        "operationId": "createContact",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactWrite"
              },
              "examples": {
                "person": {
                  "summary": "Example person contact",
                  "value": {
                    "fullName": "First Tester",
                    "name/given": "First",
                    "name/surname": "Tester",
                    "org/name": "Test Organization",
                    "emails/work": "test.user@test-user.org",
                    "addresses/work/country": "Germany",
                    "addresses/work/countryCode": "DE",
                    "phones/tel_work": "+49 123 4567890",
                    "online/url": "https://www.example.org/",
                    "notes/note": "This is a note.",
                    "egroupware.org:customfields/Test": "Content for Test"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Contact created",
            "headers": {
              "Location": {
                "description": "URL of the new resource",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactRead"
                }
              },
              "application/pretty+json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactRead"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/{username}/addressbook/{id}": {
      "get": {
        "tags": [
          "Addressbook"
        ],
        "summary": "Get a single contact",
        "description": "Retrieves a single contact by ID.",
        "operationId": "getContact",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "responses": {
          "200": {
            "description": "A single contact",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactRead"
                }
              },
              "application/pretty+json": {
                "schema": {
                  "$ref": "#/components/schemas/ContactRead"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "put": {
        "tags": [
          "Addressbook"
        ],
        "summary": "Replace a contact",
        "description": "Replaces a contact by ID. The request body uses flat slash-style field names matching EGroupware examples.",
        "operationId": "replaceContact",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactWrite"
              },
              "examples": {
                "replace": {
                  "summary": "Replace contact example",
                  "value": {
                    "fullName": "Updated Contact",
                    "name/given": "Updated",
                    "name/surname": "Contact",
                    "emails/work": "updated@example.org",
                    "phones/tel_work": "+49 555 123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Contact updated"
          },
          "201": {
            "description": "Contact created if the UID did not exist",
            "headers": {
              "Location": {
                "description": "URL of the new resource",
                "schema": {
                  "type": "string",
                  "format": "uri"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "tags": [
          "Addressbook"
        ],
        "summary": "Partially update a contact",
        "description": "Updates only the specified fields of a contact. The request body uses flat slash-style field names matching EGroupware examples.",
        "operationId": "updateContact",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ContactPatch"
              },
              "examples": {
                "patch": {
                  "summary": "Partial update example",
                  "value": {
                    "emails/work": "new.mail@example.org",
                    "phones/tel_work": "+49 999 111111",
                    "notes/note": "Updated note"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Contact partially updated"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": [
          "Addressbook"
        ],
        "summary": "Delete a contact",
        "description": "Deletes a contact by ID.",
        "operationId": "deleteContact",
        "parameters": [
          {
            "$ref": "#/components/parameters/username"
          },
          {
            "$ref": "#/components/parameters/id"
          }
        ],
        "responses": {
          "204": {
            "description": "Contact deleted"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "Basic authentication with username and password or token"
      }
    },
    "parameters": {
      "username": {
        "name": "username",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Username or user identifier"
      },
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "Contact ID or UID"
      },
      "props": {
        "name": "props[]",
        "in": "query",
        "required": false,
        "schema": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": "List of DAV properties to return, for example props[]=getetag",
        "style": "form",
        "explode": true
      },
      "syncToken": {
        "name": "sync-token",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Sync token to request changes since last sync"
      },
      "nresults": {
        "name": "nresults",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer"
        },
        "description": "Limit number of responses"
      },
      "filters_search": {
        "name": "filters[search]",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Search pattern"
      },
      "filters_linked": {
        "name": "filters[linked]",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "Search linked entries from other apps, for example <app-name>:<app-id>"
      }
    },
    "schemas": {
      "ContactWrite": {
        "type": "object",
        "description": "Request body for creating or replacing a contact. Uses flat slash-style field names as documented by EGroupware examples.",
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "fullName": {
            "type": "string",
            "description": "Full display name"
          },
          "name/given": {
            "type": "string",
            "description": "Given name"
          },
          "name/surname": {
            "type": "string",
            "description": "Family name"
          },
          "org/name": {
            "type": "string",
            "description": "Organization name"
          },
          "organizations/org/name": {
            "type": "string",
            "description": "Organization name, as shown in some EGroupware examples"
          },
          "emails/work": {
            "type": "string",
            "format": "email",
            "description": "Work email address"
          },
          "addresses/work/country": {
            "type": "string",
            "description": "Work address country"
          },
          "addresses/work/countryCode": {
            "type": "string",
            "description": "Work address country code"
          },
          "phones/tel_work": {
            "type": "string",
            "description": "Work phone number"
          },
          "online/url": {
            "type": "string",
            "format": "uri",
            "description": "URL"
          },
          "notes/note": {
            "type": "string",
            "description": "Contact note"
          }
        },
        "example": {
          "fullName": "First Tester",
          "name/given": "First",
          "name/surname": "Tester",
          "org/name": "Test Organization",
          "emails/work": "test.user@test-user.org",
          "addresses/work/country": "Germany",
          "addresses/work/countryCode": "DE",
          "phones/tel_work": "+49 123 4567890",
          "online/url": "https://www.example.org/",
          "notes/note": "This is a note.",
          "egroupware.org:customfields/Test": "Content for Test"
        }
      },
      "ContactPatch": {
        "type": "object",
        "description": "Partial update payload. Uses the same flat slash-style fields as ContactWrite, but only send the fields that should change.",
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "fullName": {
            "type": "string"
          },
          "name/given": {
            "type": "string"
          },
          "name/surname": {
            "type": "string"
          },
          "org/name": {
            "type": "string"
          },
          "organizations/org/name": {
            "type": "string"
          },
          "emails/work": {
            "type": "string",
            "format": "email"
          },
          "addresses/work/country": {
            "type": "string"
          },
          "addresses/work/countryCode": {
            "type": "string"
          },
          "phones/tel_work": {
            "type": "string"
          },
          "online/url": {
            "type": "string",
            "format": "uri"
          },
          "notes/note": {
            "type": "string"
          }
        },
        "example": {
          "emails/work": "new.mail@example.org",
          "phones/tel_work": "+49 999 111111",
          "notes/note": "Updated note"
        }
      },
      "ContactRead": {
        "type": "object",
        "description": "Contact object returned by EGroupware. Responses may contain JsContact-like fields and vendor-specific keys.",
        "additionalProperties": true,
        "properties": {
          "@type": {
            "type": "string",
            "description": "Resource type"
          },
          "uid": {
            "type": "string",
            "description": "Unique identifier"
          },
          "prodId": {
            "type": "string",
            "description": "Product identifier"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          },
          "fullName": {
            "type": "string"
          },
          "name": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NameComponent"
            }
          },
          "emails": {
            "type": "object",
            "additionalProperties": true
          },
          "phones": {
            "type": "object",
            "additionalProperties": true
          },
          "addresses": {
            "type": "object",
            "additionalProperties": true
          },
          "organizations": {
            "type": "object",
            "additionalProperties": true
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "egroupware.org:customfields": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "NameComponent": {
        "type": "object",
        "required": [
          "@type",
          "type",
          "value"
        ],
        "properties": {
          "@type": {
            "type": "string",
            "enum": [
              "NameComponent"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "title",
              "given",
              "given2",
              "surname",
              "surname2",
              "credential",
              "generation",
              "separator"
            ]
          },
          "value": {
            "type": "string"
          }
        }
      },
      "ContactCollection": {
        "type": "object",
        "properties": {
          "responses": {
            "type": "object",
            "additionalProperties": {
              "nullable": true,
              "allOf": [
                {
                  "$ref": "#/components/schemas/ContactRead"
                }
              ]
            },
            "description": "Map of contact paths to contact objects or null for deleted resources"
          },
          "more-results": {
            "type": "boolean",
            "description": "Indicates if there are more results available"
          },
          "sync-token": {
            "type": "string",
            "description": "Sync token for the next request"
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Unauthorized"
                }
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Not found"
                }
              }
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "string",
                  "example": "Bad request"
                }
              }
            }
          }
        }
      }
    }
  }
}