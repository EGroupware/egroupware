BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//EGroupware//CalDAV Test//EN
BEGIN:VEVENT
UID:{{UID}}
DTSTAMP:{{DTSTAMP}}
DTSTART:{{MASTER_START}}
DTEND:{{MASTER_END}}
RRULE:FREQ=DAILY;COUNT=6
SUMMARY:iCal sync recurring test
ORGANIZER:mailto:{{ORGANIZER_MAIL}}
ATTENDEE;PARTSTAT=ACCEPTED;ROLE=CHAIR:mailto:{{ORGANIZER_MAIL}}
ATTENDEE;PARTSTAT=ACCEPTED;ROLE=REQ-PARTICIPANT:mailto:{{ATTENDEE1_MAIL}}
ATTENDEE;PARTSTAT=NEEDS-ACTION;ROLE=REQ-PARTICIPANT:mailto:{{ATTENDEE2_MAIL}}
END:VEVENT
BEGIN:VEVENT
UID:{{UID}}
DTSTAMP:{{DTSTAMP}}
RECURRENCE-ID:{{RECURRENCE_ID}}
DTSTART:{{EXCEPTION_START}}
DTEND:{{EXCEPTION_END}}
SUMMARY:iCal sync recurring test exception
ORGANIZER:mailto:{{ORGANIZER_MAIL}}
ATTENDEE;PARTSTAT=ACCEPTED;ROLE=CHAIR:mailto:{{ORGANIZER_MAIL}}
ATTENDEE;PARTSTAT=TENTATIVE;ROLE=REQ-PARTICIPANT:mailto:{{ATTENDEE1_MAIL}}
ATTENDEE;PARTSTAT=NEEDS-ACTION;ROLE=REQ-PARTICIPANT:mailto:{{ATTENDEE2_MAIL}}
END:VEVENT
END:VCALENDAR
